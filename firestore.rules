rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    // Règle par défaut : tout est interdit
    match /{document=**} {
      allow read, write: if false;
    }

    // Tâches privées : seul le propriétaire peut lire/écrire
    match /users/{userId}/tasks/{taskId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Profil utilisateur (pour la recherche par email)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Listes partagées
    match /sharedLists/{listId} {
      function isMember() {
        return isAuthenticated() && request.auth.uid in resource.data.members;
      }

      function isOwner() {
        return isMember() && resource.data.ownerId == request.auth.uid;
      }

      function isAdmin() {
        return isMember() && resource.data.memberRoles[request.auth.uid] == "admin";
      }

      // Lecture : seuls les membres peuvent lire
      allow read: if isMember();

      // Création : tout utilisateur connecté peut créer une liste
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.ownerId
        && request.auth.uid in request.resource.data.members
        && request.resource.data.memberRoles[request.auth.uid] == "owner";

      // Mise à jour :
      // - owner : tout
      // - admin : uniquement la map des rôles, sans changer nom/owner/membres
      allow update: if isOwner()
        || (
          isAdmin()
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.name == resource.data.name
          && request.resource.data.members == resource.data.members
          && request.resource.data.createdAt == resource.data.createdAt
        );

      // Suppression : seul le owner peut supprimer
      allow delete: if isOwner();

      // Tâches d'une liste partagée :
      // - lecture : membres
      // - écriture : owner/admin/editor (reader = lecture seule)
      match /tasks/{taskId} {
        allow read: if isAuthenticated()
          && request.auth.uid in
          get(/databases/$(database)/documents/sharedLists/$(listId)).data.members;

        allow write: if isAuthenticated()
          && request.auth.uid in
          get(/databases/$(database)/documents/sharedLists/$(listId)).data.members
          && (
            // compatibilité anciennes listes sans memberRoles
            !("memberRoles" in get(/databases/$(database)/documents/sharedLists/$(listId)).data)
            || get(/databases/$(database)/documents/sharedLists/$(listId)).data.memberRoles[request.auth.uid] in ["owner", "admin", "editor"]
          );
      }
    }
  }
}
